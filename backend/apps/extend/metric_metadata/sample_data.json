{
  "description": "指标元数据示例数据 - 可直接用于测试",
  "usage": "使用 POST /extend/metric-metadata/batch 接口批量导入",
  
  "sample_data": [
    {
      "metric_name": "销售额",
      "synonyms": "营收，销售收入，卖钱额，GMV",
      "datasource_id": 1,
      "table_name": "orders",
      "core_fields": "order_id, user_id, amount, pay_time, create_time",
      "calc_logic": "SUM(amount) WHERE pay_time IS NOT NULL",
      "upstream_table": "order_items, cart",
      "dw_layer": "DWS"
    },
    {
      "metric_name": "订单量",
      "synonyms": "订单数，下单数量，成交订单数",
      "datasource_id": 1,
      "table_name": "orders",
      "core_fields": "order_id, user_id, create_time, order_status",
      "calc_logic": "COUNT(DISTINCT order_id) WHERE order_status != 'cancelled'",
      "upstream_table": null,
      "dw_layer": "DWS"
    },
    {
      "metric_name": "客单价",
      "synonyms": "人均消费，ARPU, 平均订单金额",
      "datasource_id": 1,
      "table_name": "orders",
      "core_fields": "user_id, amount",
      "calc_logic": "SUM(amount) / COUNT(DISTINCT user_id)",
      "upstream_table": "orders",
      "dw_layer": "ADS"
    },
    {
      "metric_name": "毛利率",
      "synonyms": "毛利，利润率，盈利比例",
      "datasource_id": 2,
      "table_name": "sales_summary",
      "core_fields": "revenue, cost, profit",
      "calc_logic": "(revenue - cost) / revenue * 100",
      "upstream_table": "cost_detail, sales_detail",
      "dw_layer": "ADS"
    },
    {
      "metric_name": "日活用户",
      "synonyms": "DAU, 活跃用户数，日活跃用户",
      "datasource_id": 1,
      "table_name": "user_login",
      "core_fields": "user_id, login_date, login_time",
      "calc_logic": "COUNT(DISTINCT user_id) WHERE login_date = CURRENT_DATE",
      "upstream_table": "user_info",
      "dw_layer": "DWS"
    },
    {
      "metric_name": "月活用户",
      "synonyms": "MAU, 月活跃用户数",
      "datasource_id": 1,
      "table_name": "user_login",
      "core_fields": "user_id, login_date",
      "calc_logic": "COUNT(DISTINCT user_id) WHERE login_date >= DATE_TRUNC('month', CURRENT_DATE)",
      "upstream_table": "user_info",
      "dw_layer": "DWS"
    },
    {
      "metric_name": "转化率",
      "synonyms": "购买转化率，下单转化率",
      "datasource_id": 1,
      "table_name": "conversion_funnel",
      "core_fields": "step, user_count, date",
      "calc_logic": "users_completed_step / users_started_step * 100",
      "upstream_table": "user_behavior",
      "dw_layer": "ADS"
    },
    {
      "metric_name": "复购率",
      "synonyms": "回购率，再次购买率",
      "datasource_id": 1,
      "table_name": "user_orders",
      "core_fields": "user_id, order_count, first_order_date, last_order_date",
      "calc_logic": "users_with_orders > 1 / total_users * 100",
      "upstream_table": "orders",
      "dw_layer": "ADS"
    },
    {
      "metric_name": "库存周转率",
      "synonyms": "存货周转率，库存周转天数",
      "datasource_id": 3,
      "table_name": "inventory_summary",
      "core_fields": "product_id, stock_quantity, sales_quantity, period",
      "calc_logic": "COGS / AVG(inventory_balance)",
      "upstream_table": "inventory_detail, sales_detail",
      "dw_layer": "DWS"
    },
    {
      "metric_name": "退货率",
      "synonyms": "退款率，退换货比例",
      "datasource_id": 1,
      "table_name": "return_orders",
      "core_fields": "return_id, order_id, return_amount, return_reason",
      "calc_logic": "COUNT(return_orders) / COUNT(orders) * 100",
      "upstream_table": "orders, return_items",
      "dw_layer": "ADS"
    }
  ],
  
  "test_commands": {
    "1_查看示例数据": "GET http://localhost:8000/extend/metric-metadata/test/sample-data",
    "2_插入示例数据": "POST http://localhost:8000/extend/metric-metadata/test/insert-sample",
    "3_查询所有数据": "GET http://localhost:8000/extend/metric-metadata/list",
    "4_分页查询": "GET http://localhost:8000/extend/metric-metadata/page/1/10",
    "5_按名称查询": "GET http://localhost:8000/extend/metric-metadata/test/query?metric_name=销售",
    "6_填充 embedding": "POST http://localhost:8000/extend/metric-metadata/fill-embeddings",
    "7_清空测试数据": "DELETE http://localhost:8000/extend/metric-metadata/test/clear-all"
  },
  
  "api_endpoints": {
    "创建单个": "PUT /extend/metric-metadata",
    "批量创建": "POST /extend/metric-metadata/batch",
    "查询详情": "GET /extend/metric-metadata/{id}",
    "分页查询": "GET /extend/metric-metadata/page/{current_page}/{page_size}",
    "列表查询": "GET /extend/metric-metadata/list",
    "删除": "DELETE /extend/metric-metadata?ids=[1,2,3]"
  }
}
